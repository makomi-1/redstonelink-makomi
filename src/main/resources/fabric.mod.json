{
	"schemaVersion": 1,
	"id": "redstonelink",
	"version": "${version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": [
		"${mod_authors}"
	],
	"contact": {
		"homepage": "${mod_homepage}",
		"sources": "${mod_sources}"
	},
	"license": "${mod_license}",
	"icon": "assets/redstonelink/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.makomi.RedstoneLink"
		],
		"client": [
			"com.makomi.RedstoneLinkClient"
		],
		"fabric-datagen": [
			"com.makomi.RedstoneLinkDataGenerator"
		]
	},
	"mixins": [
		"redstonelink.mixins.json",
		{
			"config": "redstonelink.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}